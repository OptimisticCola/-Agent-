# ============================================
# 后端 API Dockerfile
# ============================================
FROM python:3.11-slim

WORKDIR /app

# 安装依赖
COPY backend/requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

# 复制代码
COPY backend/ /app/

# 初始化知识库并启动
CMD python scripts/init_knowledge.py && uvicorn main:app --host 0.0.0.0 --port 8000
