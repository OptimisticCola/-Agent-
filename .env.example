# ============================================
# 智能客服 Agent 系统 - 环境变量配置
# ============================================

# --- LLM 配置 (OpenAI 兼容 API) ---
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7

# --- Milvus 向量数据库 ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=customer_service_knowledge

# --- Chroma (本地知识库) ---
CHROMA_PERSIST_DIR=./backend/chroma_data

# --- 后端服务 ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- 前端 ---
VITE_API_BASE_URL=http://localhost:8000

# --- MCP Servers ---
MCP_KNOWLEDGE_PORT=8001
MCP_TICKET_PORT=8002
MCP_ORDER_PORT=8003
MCP_HUMAN_PORT=8004

# --- 日志 ---
LOG_LEVEL=INFO

# --- Docker ---
COMPOSE_PROJECT_NAME=agent-customer-service
